options:
  parameters:
    author: Maxim
    catch_exceptions: 'True'
    category: Custom
    cmake_opt: ''
    comment: ''
    copyright: ''
    description: 'ZMQ Channel Broker for srsRAN 5G NR — sits between gNB and UE,

      applies AWGN + Rician/Rayleigh fading to IQ samples while preserving ZMQ

      REQ/REP message boundaries (23040 samples/subframe at 23.04 MHz).'
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: qt_gui
    hier_block_src_path: '.:'
    id: srsran_channel_broker
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: srsRAN 5G NR Channel Broker
    window_size: (1280, 1024)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

blocks:
# ── Variables ──────────────────────────────────────────────────────────────
- name: samp_rate
  id: variable
  parameters:
    comment: ''
    value: 23.04e6
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 100]
    rotation: 0
    state: enabled

- name: snr_db
  id: variable
  parameters:
    comment: ''
    value: '28.0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 180]
    rotation: 0
    state: enabled

- name: k_factor_db
  id: variable
  parameters:
    comment: ''
    value: '3.0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 260]
    rotation: 0
    state: enabled

- name: doppler_hz
  id: variable
  parameters:
    comment: ''
    value: '5.0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 340]
    rotation: 0
    state: enabled

- name: fading_en
  id: variable
  parameters:
    comment: ''
    value: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 420]
    rotation: 0
    state: enabled

- name: gnb_tx_port
  id: variable
  parameters:
    comment: ''
    value: '4000'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 500]
    rotation: 0
    state: enabled

- name: gnb_rx_port
  id: variable
  parameters:
    comment: ''
    value: '4001'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 580]
    rotation: 0
    state: enabled

- name: ue_rx_port
  id: variable
  parameters:
    comment: ''
    value: '2000'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [120, 500]
    rotation: 0
    state: enabled

- name: ue_tx_port
  id: variable
  parameters:
    comment: ''
    value: '2001'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [120, 580]
    rotation: 0
    state: enabled

- name: noise_voltage
  id: variable
  parameters:
    comment: ''
    value: 1.0 / math.sqrt(2.0 * pow(10, snr_db / 10.0))
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [120, 180]
    rotation: 0
    state: enabled

